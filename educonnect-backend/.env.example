MONGO_URI=mongodb://127.0.0.1:27017/educonnect
PORT=5000
NODE_ENV=development

# Admin Credentials
ADMIN_EMAIL=admin@educonnect.com
ADMIN_PASSWORD=your_secure_password_here

# ==========================================
# CORS Configuration - Multiple Origins
# ==========================================
# By default, the following origins are ALWAYS allowed:
# - http://localhost:3000
# - http://localhost:3001
# - http://127.0.0.1:3000

# For production Netlify deployment, set:
NETLIFY_URL=https://your-app.netlify.app

# Additional CORS origins (comma-separated, no spaces):
# Example: https://example.com,https://admin.example.com
CORS_ORIGINS=

# ==========================================
# Session Management
# ==========================================
SESSION_TTL_MS=3600000

# ==========================================
# Firebase Configuration
# ==========================================
FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
FIREBASE_AUTH_DOMAIN=YOUR_FIREBASE_AUTH_DOMAIN
FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID
FIREBASE_STORAGE_BUCKET=YOUR_FIREBASE_STORAGE_BUCKET
FIREBASE_MESSAGING_SENDER_ID=YOUR_FIREBASE_MESSAGING_SENDER_ID
FIREBASE_APP_ID=YOUR_FIREBASE_APP_ID

# ==========================================
# Socket.io CORS (comma-separated)
# ==========================================
SOCKET_IO_CORS_ORIGIN=http://localhost:3000,https://your-app.netlify.app
